{
  "version": 2,
  "builds": [
    { "src": "api/chart.py",  "use": "@vercel/python" },
    { "src": "api/index.py",  "use": "@vercel/python" },
    { "src": "index.html",    "use": "@vercel/static"  }
  ],
  "routes": [
    { "src": "/api/chart",    "dest": "/api/chart.py"  },
    { "src": "/api/(.*)",     "dest": "/api/index.py"  },
    { "src": "/(.*)",         "dest": "/index.html"    }
  ]
}
